# Obtenha sua chave em: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Em produção: coloque o IP ou domínio do servidor (ex: http://1.2.3.4:3000)
# Deixe em branco para usar o padrão localhost:3000
CORS_ORIGINS=http://localhost:3000

# Proxy residencial para o yt-dlp (evita bloqueio do YouTube em datacenters)
# Formato: http://usuario:senha@host:porta
# Obtenha em: https://webshare.io
YTDLP_PROXY=
